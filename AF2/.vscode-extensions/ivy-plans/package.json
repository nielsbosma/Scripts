{
  "name": "ivy-plans",
  "displayName": "Ivy Plans",
  "description": "Plan management commands: Update, Approve, Split, and Make plans",
  "version": "0.1.0",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "ivy.updatePlan", "title": "Ivy: Update Plan" },
      { "command": "ivy.approvePlan", "title": "Ivy: Approve Plan" },
      { "command": "ivy.splitPlan", "title": "Ivy: Split Plan" },
      { "command": "ivy.skipPlan", "title": "Ivy: Skip Plan" },
      { "command": "ivy.makePlan", "title": "Ivy: Make Plan" },
      { "command": "ivy.createIvyFrameworkIssue", "title": "Ivy: Create Ivy-Framework Issue" }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "ivy.approvePlan",
          "when": "resourceExtname == .md",
          "group": "2_workspace@1"
        },
        {
          "command": "ivy.updatePlan",
          "when": "resourceExtname == .md",
          "group": "2_workspace@2"
        },
        {
          "command": "ivy.splitPlan",
          "when": "resourceExtname == .md",
          "group": "2_workspace@3"
        },
        {
          "command": "ivy.skipPlan",
          "when": "resourceExtname == .md",
          "group": "2_workspace@4"
        },
        {
          "command": "ivy.makePlan",
          "group": "2_workspace@5"
        },
        {
          "command": "ivy.createIvyFrameworkIssue",
          "when": "resourceExtname == .md",
          "group": "2_workspace@6"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ivy.makePlan",
        "key": "ctrl+alt+m"
      },
      {
        "command": "ivy.updatePlan",
        "key": "ctrl+alt+u",
        "when": "editorTextFocus && resourceExtname == .md"
      },
      {
        "command": "ivy.approvePlan",
        "key": "ctrl+alt+a",
        "when": "editorTextFocus && resourceExtname == .md"
      },
      {
        "command": "ivy.splitPlan",
        "key": "ctrl+alt+s",
        "when": "editorTextFocus && resourceExtname == .md"
      },
      {
        "command": "ivy.skipPlan",
        "key": "ctrl+alt+k",
        "when": "editorTextFocus && resourceExtname == .md"
      },
      {
        "command": "ivy.createIvyFrameworkIssue",
        "key": "ctrl+alt+i",
        "when": "editorTextFocus && resourceExtname == .md"
      }
    ]
  }
}

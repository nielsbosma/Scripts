{
  "name": "ivy-plans",
  "displayName": "Ivy Plans",
  "description": "Plan management commands: Update, Approve, Split, and Make plans",
  "version": "0.1.0",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "ivy.updatePlan", "title": "Ivy: Update Plan", "icon": { "light": "icons/update-light.svg", "dark": "icons/update-dark.svg" } },
      { "command": "ivy.expandPlan", "title": "Ivy: Expand Plan", "icon": { "light": "icons/expand-light.svg", "dark": "icons/expand-dark.svg" } },
      { "command": "ivy.approvePlan", "title": "Ivy: Approve Plan", "icon": { "light": "icons/approve-light.svg", "dark": "icons/approve-dark.svg" } },
      { "command": "ivy.splitPlan", "title": "Ivy: Split Plan", "icon": { "light": "icons/split-light.svg", "dark": "icons/split-dark.svg" } },
      { "command": "ivy.skipPlan", "title": "Ivy: Skip Plan", "icon": { "light": "icons/skip-light.svg", "dark": "icons/skip-dark.svg" } },
      { "command": "ivy.makePlan", "title": "Ivy: Make Plan" },
      { "command": "ivy.createIvyFrameworkIssue", "title": "Ivy: Create Ivy-Framework Issue" },
      { "command": "ivy.createIvyMcpIssue", "title": "Ivy: Create Ivy-Mcp Issue" },
      { "command": "ivy.testPlan", "title": "Ivy: Test" },
      { "command": "ivy.followUpPlan", "title": "Ivy: Follow-Up Plan" },
      { "command": "ivy.executePlan", "title": "Ivy: Execute Plan" }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ivy.approvePlan",
          "when": "resourceExtname == .md && resourcePath =~ /\\.plans[/\\\\]/",
          "group": "navigation"
        },
        {
          "command": "ivy.updatePlan",
          "when": "resourceExtname == .md && resourcePath =~ /\\.plans[/\\\\]/",
          "group": "navigation"
        },
        {
          "command": "ivy.splitPlan",
          "when": "resourceExtname == .md && resourcePath =~ /\\.plans[/\\\\]/",
          "group": "navigation"
        },
        {
          "command": "ivy.expandPlan",
          "when": "resourceExtname == .md && resourcePath =~ /\\.plans[/\\\\]/",
          "group": "navigation"
        },
        {
          "command": "ivy.skipPlan",
          "when": "resourceExtname == .md && resourcePath =~ /\\.plans[/\\\\]/",
          "group": "navigation"
        },
        {
          "command": "ivy.executePlan",
          "when": "resourceExtname == .md && resourcePath =~ /\\.plans[/\\\\]/",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "ivy.approvePlan",
          "when": "resourceExtname == .md",
          "group": "2_workspace@1"
        },
        {
          "command": "ivy.updatePlan",
          "when": "resourceExtname == .md",
          "group": "2_workspace@2"
        },
        {
          "command": "ivy.expandPlan",
          "when": "resourceExtname == .md",
          "group": "2_workspace@3"
        },
        {
          "command": "ivy.splitPlan",
          "when": "resourceExtname == .md",
          "group": "2_workspace@4"
        },
        {
          "command": "ivy.skipPlan",
          "when": "resourceExtname == .md",
          "group": "2_workspace@5"
        },
        {
          "command": "ivy.makePlan",
          "group": "2_workspace@6"
        },
        {
          "command": "ivy.createIvyFrameworkIssue",
          "when": "resourceExtname == .md",
          "group": "2_workspace@7"
        },
        {
          "command": "ivy.createIvyMcpIssue",
          "when": "resourceExtname == .md",
          "group": "2_workspace@8"
        },
        {
          "command": "ivy.testPlan",
          "when": "resourceExtname == .md",
          "group": "2_workspace@9"
        },
        {
          "command": "ivy.followUpPlan",
          "when": "resourceExtname == .md",
          "group": "2_workspace@10"
        },
        {
          "command": "ivy.executePlan",
          "when": "resourceExtname == .md",
          "group": "2_workspace@11"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ivy.makePlan",
        "key": "ctrl+alt+m"
      },
      {
        "command": "ivy.updatePlan",
        "key": "ctrl+alt+u",
        "when": "editorTextFocus && resourceExtname == .md"
      },
      {
        "command": "ivy.expandPlan",
        "key": "ctrl+alt+e",
        "when": "editorTextFocus && resourceExtname == .md"
      },
      {
        "command": "ivy.approvePlan",
        "key": "ctrl+alt+a",
        "when": "editorTextFocus && resourceExtname == .md"
      },
      {
        "command": "ivy.splitPlan",
        "key": "ctrl+alt+s",
        "when": "editorTextFocus && resourceExtname == .md"
      },
      {
        "command": "ivy.skipPlan",
        "key": "ctrl+alt+k",
        "when": "editorTextFocus && resourceExtname == .md"
      },
      {
        "command": "ivy.createIvyFrameworkIssue",
        "key": "ctrl+alt+i",
        "when": "editorTextFocus && resourceExtname == .md"
      },
      {
        "command": "ivy.testPlan",
        "key": "ctrl+alt+t",
        "when": "editorTextFocus && resourceExtname == .md"
      },
      {
        "command": "ivy.executePlan",
        "key": "ctrl+alt+x",
        "when": "editorTextFocus && resourceExtname == .md"
      }
    ]
  }
}
